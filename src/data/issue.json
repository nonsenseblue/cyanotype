  "about": {
    "title": {
      "en": "About",
      "jp": "わたしについて",
      "cn": "关于"
    },
    "body": [
      {
        "en": "My name is SylviaHuang. You can also call me minmin.",
        "jp": "わたしは SylviaHuang。 みんみんと呼んでくれてもいい。",
        "cn": "我叫 SylviaHuang，也可以叫我 minmin。"
      },
      {
        "en": "A beginner with a camera.",
        "jp": "カメラ初心者です。",
        "cn": "相机新手。"
      },
      {
        "en": "Sony A7M3, one body.",
        "jp": "Sony A7M3、一台だけ。",
        "cn": "索尼 A7M3，一台。"
      },
      {
        "en": "Sony 50mm prime, Tamron 25–200mm zoom — only these two.",
        "jp": "Sony 50mm 単焦点、Tamron 25–200mm ズーム——この二本だけ。",
        "cn": "索尼定焦 50mm，腾龙变焦 25–200mm。只有这两支。"
      },
      {
        "en": "I don't know the techniques. I only want to keep the feel of the air, just as it was.",
        "jp": "技術はわかりません。ただ、その瞬間の空気を、そのまま留めておきたい。",
        "cn": "不懂任何技术，只想记录当下的那份空气。"
      },
      {
        "en": "Thank you for stopping by.",
        "jp": "立ち寄ってくださって、ありがとう。",
        "cn": "欢迎到访。"
      }
    ],
    "instagram": "0101infinite",
